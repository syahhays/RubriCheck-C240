<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | Feedback</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { activePage: '' }) %>

  <%
    const generatedReport = typeof report === 'undefined' ? null : report;
    const generatedSummary = typeof summary === 'undefined' || !summary ? {} : summary;
    const uploadedFiles = typeof files === 'undefined' ? null : files;
    const generatedReviewId = typeof reviewId === 'undefined' ? null : reviewId;
    const student = typeof studentInfo === 'undefined' || !studentInfo ? {} : studentInfo;

    function asPercent(value, fallback) {
      const numberValue = Number(value);
      return Number.isFinite(numberValue) ? Math.max(0, Math.min(100, Math.round(numberValue))) : fallback;
    }

    function listOrFallback(value, fallback) {
      return Array.isArray(value) && value.length > 0 ? value : fallback;
    }

    function formatDeadline(value) {
      if (!value) {
        return 'Not provided';
      }

      const date = new Date(`${value}T23:59:00`);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return date.toLocaleString('en-SG', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
    }

    const completionPercent = asPercent(generatedSummary.completionPercentage, 0);
    const readinessScore = asPercent(generatedSummary.readinessScore, completionPercent);
    const readinessLevel = generatedSummary.readinessLevel || 'Needs Review';
    const finalRecommendation = generatedSummary.finalRecommendation || 'Review Before Submission';
    const topPriorities = listOrFallback(generatedSummary.topPriorities, ['Review the full feedback report', 'Fix missing rubric requirements', 'Check evidence before submission']);
    const checklist = listOrFallback(generatedSummary.checklist, ['Review all rubric requirements', 'Check citations and references', 'Proofread before submission']);
    const missingWeakAreas = listOrFallback(generatedSummary.missingWeakAreas, ['Review the full feedback report for weak areas']);
    const reportText = generatedSummary.fullFeedback || generatedReport;
    const icons = {
      check: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>',
      sparkles: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z"/><path d="M19 16l.8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16Z"/></svg>',
      target: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><path d="M12 12l5-5"/></svg>',
      clipboard: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5h6"/><path d="M9 4h6l1 2h3v14H5V6h3l1-2Z"/><path d="m9 13 2 2 4-4"/></svg>',
      bell: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 17h12l-1.5-2.5V10a4.5 4.5 0 0 0-9 0v4.5L6 17Z"/><path d="M10 20h4"/></svg>',
      alert: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4 3 20h18L12 4Z"/><path d="M12 9v5"/><path d="M12 17h.01"/></svg>',
      chat: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6h14v10H8l-3 3V6Z"/><path d="M8 10h8"/><path d="M8 13h5"/></svg>',
      document: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l4 4v14H7V3Z"/><path d="M14 3v5h5"/><path d="M10 13h5"/><path d="M10 17h5"/></svg>',
      send: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 3-8 18-3-8-8-3 19-7Z"/><path d="m10 13 5-5"/></svg>',
      lock: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="10" width="12" height="10" rx="2"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>'
    };

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatInlineMarkdown(value) {
      return escapeHtml(value).replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    }

    function formatReportHtml(value) {
      const lines = String(value || '').split(/\r?\n/);
      const html = [];
      let listOpen = false;

      function closeList() {
        if (listOpen) {
          html.push('</ul>');
          listOpen = false;
        }
      }

      lines.forEach((line) => {
        const trimmed = line.trim();

        if (!trimmed) {
          closeList();
          return;
        }

        const headingMatch = trimmed.match(/^(#{1,4})\s+(.+)$/);
        if (headingMatch) {
          closeList();
          const level = Math.min(headingMatch[1].length + 1, 4);
          html.push(`<h${level}>${formatInlineMarkdown(headingMatch[2])}</h${level}>`);
          return;
        }

        const bulletMatch = trimmed.match(/^[-*]\s+(.+)$/);
        if (bulletMatch) {
          if (!listOpen) {
            html.push('<ul>');
            listOpen = true;
          }
          html.push(`<li>${formatInlineMarkdown(bulletMatch[1])}</li>`);
          return;
        }

        closeList();
        html.push(`<p>${formatInlineMarkdown(trimmed)}</p>`);
      });

      closeList();
      return html.join('');
    }
  %>

  <main class="feedback-page">
    <section class="feedback-shell container">
      <% if (generatedReport) { %>
        <section class="analysis-complete-card" aria-labelledby="analysis-complete-title">
          <div class="analysis-status-icon" aria-hidden="true"><%- icons.check %></div>
          <div>
            <h1 id="analysis-complete-title">Analysis Complete!</h1>
            <p>Your assignment has been analysed using AI.</p>
          </div>
          <a class="btn btn-secondary banner-review-button" href="/upload"><%- icons.document %> Start New Review</a>
        </section>

        <section class="feedback-dashboard-card feedback-overview-card" aria-labelledby="assignment-feedback-title">
          <div class="feedback-overview-header">
            <div class="section-title-row">
              <span class="section-icon blue" aria-hidden="true"><%- icons.sparkles %></span>
              <div>
                <h2 id="assignment-feedback-title">AI Assignment Feedback</h2>
                <% if (student.assignmentName || student.moduleCode) { %>
                  <p><%= student.assignmentName || 'Assignment review' %><%= student.moduleCode ? ` - ${student.moduleCode}` : '' %></p>
                <% } %>
              </div>
            </div>
            <span class="feedback-status-pill"><%= finalRecommendation %></span>
          </div>

          <div class="feedback-scoreboard">
            <article class="feedback-stat-card">
              <span>Completion</span>
              <strong class="blue-text"><%= completionPercent %>%</strong>
              <div class="stat-progress"><span style="width: <%= completionPercent %>%"></span></div>
              <small><%= completionPercent >= 70 ? 'Good progress' : 'Needs more work' %></small>
            </article>

            <article class="feedback-stat-card">
              <span>Readiness Score</span>
              <strong class="green-text"><%= readinessScore %>%</strong>
              <div class="stat-progress green"><span style="width: <%= readinessScore %>%"></span></div>
              <small><%= readinessScore >= 70 ? 'Nearly ready' : 'Needs revision' %></small>
            </article>

            <article class="readiness-summary-card">
              <div class="readiness-level-panel">
                <span>Readiness Level</span>
                <strong class="readiness-badge"><%= readinessLevel %></strong>
              </div>
              <div class="recommendation-inline">
                <span class="mini-icon" aria-hidden="true"><%- icons.document %></span>
                <div>
                  <span>Recommendation</span>
                  <strong><%= finalRecommendation %></strong>
                  <small>Review the priority fixes before final submission.</small>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="feedback-dashboard-card review-table-card" aria-labelledby="review-table-title">
          <div class="section-title-row">
            <span class="section-icon blue" aria-hidden="true"><%- icons.document %></span>
            <div>
              <h2 id="review-table-title">Review Summary</h2>
              <p>Key assignment details and AI readiness signals.</p>
            </div>
          </div>

          <div class="responsive-table">
            <table>
              <tbody>
                <tr>
                  <th scope="row">Student</th>
                  <td><%= student.studentName || 'Not provided' %></td>
                  <th scope="row">Module</th>
                  <td><%= student.moduleCode || 'Not provided' %></td>
                </tr>
                <tr>
                  <th scope="row">Assignment</th>
                  <td><%= student.assignmentName || 'Not provided' %></td>
                  <th scope="row">Deadline</th>
                  <td><%= formatDeadline(student.deadline) %></td>
                </tr>
                <tr>
                  <th scope="row">Readiness Level</th>
                  <td><span class="readiness-badge table-badge"><%= readinessLevel %></span></td>
                  <th scope="row">Recommendation</th>
                  <td><%= finalRecommendation %></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <div class="feedback-insight-grid">
          <section class="feedback-dashboard-card compact-card" aria-labelledby="priorities-title">
            <div class="section-title-row">
              <span class="section-icon blue" aria-hidden="true"><%- icons.target %></span>
              <h2 id="priorities-title">Top 3 Priorities</h2>
            </div>
            <ol class="priority-list">
              <% topPriorities.slice(0, 3).forEach((priority, index) => { %>
                <li><span><%= index + 1 %></span><%= priority %></li>
              <% }); %>
            </ol>
          </section>

          <section class="feedback-dashboard-card compact-card" aria-labelledby="checklist-title">
            <div class="section-title-row">
              <span class="section-icon green" aria-hidden="true"><%- icons.clipboard %></span>
              <h2 id="checklist-title">Before Submission Checklist</h2>
            </div>
            <ul class="clean-checklist">
              <% checklist.slice(0, 5).forEach((item) => { %>
                <li><span aria-hidden="true"></span><%= item %></li>
              <% }); %>
            </ul>
          </section>
        </div>

        <section class="feedback-dashboard-card missing-weak-card" aria-labelledby="weak-areas-title">
          <div class="section-title-row">
            <span class="section-icon red" aria-hidden="true"><%- icons.alert %></span>
            <h2 id="weak-areas-title">Missing / Weak Areas</h2>
          </div>
          <ul>
            <% missingWeakAreas.slice(0, 6).forEach((area) => { %>
              <li><%= area %></li>
            <% }); %>
          </ul>
        </section>

        <aside class="feedback-dashboard-card reminder-setup-card" aria-labelledby="reminder-title">
          <div class="section-title-row">
            <span class="section-icon purple" aria-hidden="true"><%- icons.bell %></span>
            <h2 id="reminder-title">Reminder Setup</h2>
          </div>

          <div class="reminder-compact-grid">
            <label>
              Telegram Chat ID
              <input type="text" value="<%= student.telegramChatId || '' %>" readonly>
            </label>

            <label>
              Deadline
              <input type="text" value="<%= formatDeadline(student.deadline) %>" readonly>
            </label>

            <div class="reminder-info-box">
              <span><%- icons.check %> You'll receive reminders</span>
              <span><%- icons.check %> 1 day before the deadline</span>
              <span><%- icons.check %> On the deadline day</span>
            </div>

            <div class="reminder-action-stack">
              <a class="btn btn-success reminder-enable-button" href="<%= generatedReviewId ? `/reminder?reviewId=${encodeURIComponent(generatedReviewId)}` : '/reminder' %>"><%- icons.send %> Enable Telegram Reminder</a>
              <p class="reminder-privacy-note"><%- icons.lock %> Your information is secure and will only be used for reminders.</p>
            </div>
          </div>
        </aside>

        <section class="feedback-dashboard-card follow-up-dashboard-card" aria-labelledby="follow-up-title">
          <div class="section-title-row">
            <span class="section-icon purple" aria-hidden="true"><%- icons.chat %></span>
            <div>
              <h2 id="follow-up-title">Ask Follow-Up Questions</h2>
              <p>Ask anything about your feedback and get AI-powered explanations.</p>
            </div>
          </div>

          <form class="follow-up-inline-form" data-follow-up-form>
            <input type="hidden" name="reviewId" value="<%= generatedReviewId %>">
            <label for="follow-up-question" class="sr-only">Follow-up question</label>
            <input id="follow-up-question" name="question" maxlength="1000" placeholder="e.g. Why is my score low?" required data-follow-up-question>
            <button class="btn btn-primary" type="submit" data-follow-up-submit><%- icons.send %> Send</button>
          </form>

          <div class="chat-response-row">
            <span class="chat-avatar" aria-hidden="true"><%- icons.sparkles %></span>
            <div>
              <article class="follow-up-answer sample-answer" aria-live="polite">
                Ask a follow-up question to get a focused explanation based on this feedback report.
              </article>
              <article class="follow-up-answer hidden" data-follow-up-answer aria-live="polite"></article>
              <p class="follow-up-timestamp">AI response generated just now</p>
            </div>
          </div>
          <p class="follow-up-error hidden" data-follow-up-error role="alert"></p>
        </section>

        <section class="feedback-footer-card">
          <details class="full-feedback-details">
            <summary><span><%- icons.document %> View Full AI Feedback Report</span><span class="details-chevron" aria-hidden="true">v</span></summary>
            <div class="ai-report-formatted"><%- formatReportHtml(reportText) %></div>
          </details>
        </section>

        <section class="feedback-footer-card ai-guidance-card">
          <div class="ai-guidance-header">
            <div class="section-title-row">
              <span class="section-icon blue" aria-hidden="true"><%- icons.sparkles %></span>
              <div>
                <h2>AI-Powered Feedback</h2>
                <p>This feedback is generated by AI and should be used as a guide to improve your assignment.</p>
              </div>
            </div>
            <a class="btn btn-secondary" href="<%= generatedReviewId ? `/questions?reviewId=${encodeURIComponent(generatedReviewId)}` : '/questions' %>">Prepare Lecturer Questions</a>
          </div>

          <div class="ai-guidance-actions">
            <% if (generatedReviewId) { %>
              <div class="report-download-row" aria-label="Download feedback report">
                <a class="btn btn-secondary" href="/check-assignment/<%= encodeURIComponent(generatedReviewId) %>/download.txt">Download TXT</a>
                <a class="btn btn-secondary" href="/check-assignment/<%= encodeURIComponent(generatedReviewId) %>/download.html">Download HTML</a>
              </div>
            <% } %>
          </div>

          <% if (uploadedFiles) { %>
            <div class="uploaded-file-summary compact-files">
              <div>
                <strong>Assignment Brief</strong>
                <span><%= uploadedFiles.assignmentBrief %></span>
              </div>
              <div>
                <strong>Marking Rubric</strong>
                <span><%= uploadedFiles.markingRubric %></span>
              </div>
              <div>
                <strong>Student Draft</strong>
                <span><%= uploadedFiles.studentDraft %></span>
              </div>
            </div>
          <% } %>
        </section>
      <% } else { %>
        <section class="report-empty-state">
          <h2>No feedback report yet</h2>
          <p>Start from New Review, fill in the student information, upload the assignment brief, marking rubric, and student draft, then check the assignment to generate the connected Gemini feedback report.</p>
          <a class="btn btn-primary" href="/upload">Go to New Review</a>
        </section>
      <% } %>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
