<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | Feedback</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container nav-bar">
      <a class="brand" href="/" aria-label="RubriCheck AI home">
        <img class="brand-logo" src="/images/RubriCheck%20Logo.png" alt="RubriCheck AI logo">
        <span class="brand-name">Rubri<span>Check</span> <small>AI</small></span>
      </a>

      <nav class="main-nav" aria-label="Main navigation">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/upload">New Review</a>
      </nav>

      <div class="auth-area" aria-label="Account actions">
        <button class="login-button" type="button" data-login-open>Log In</button>

        <a class="user-chip hidden" href="/dashboard" aria-label="Open user dashboard" data-user-chip>
          <span class="user-icon">DS</span>
          <span>Demo Student</span>
        </a>
      </div>
    </div>
  </header>

  <div class="modal-overlay hidden" data-login-modal>
    <section class="login-modal" role="dialog" aria-modal="true" aria-labelledby="login-title">
      <button class="modal-close" type="button" aria-label="Close login" data-login-close>&times;</button>

      <img class="modal-logo" src="/images/RubriCheck%20Logo.png" alt="RubriCheck AI logo">
      <h2 id="login-title">Log in to RubriCheck AI</h2>
      <p>This is a frontend demo login. No real account or password is needed yet.</p>

      <form class="login-form">
        <label for="demo-email">Email</label>
        <input id="demo-email" type="email" value="student@myrp.edu.sg" readonly>

        <label for="demo-password">Password</label>
        <input id="demo-password" type="password" value="password" readonly>

        <button class="btn btn-primary" type="button" data-demo-login>Use Demo Login</button>
      </form>
    </section>
  </div>

  <% const generatedReport = typeof report === 'undefined' ? null : report; %>
  <% const uploadedFiles = typeof files === 'undefined' ? null : files; %>
  <% const generatedReviewId = typeof reviewId === 'undefined' ? null : reviewId; %>

  <main class="feedback-page">
    <section class="feedback-shell container">
      <div class="feedback-header">
        <div>
          <p class="feedback-kicker">RubriCheck AI report</p>
          <h1>AI Feedback Report</h1>
          <p>Review your assignment readiness and improvement areas before submission.</p>
        </div>

        <div class="feedback-actions">
          <a class="btn btn-secondary" href="<%= generatedReviewId ? `/questions?reviewId=${encodeURIComponent(generatedReviewId)}` : '/questions' %>">Prepare Lecturer Questions</a>
          <a class="btn btn-secondary" href="/upload">Check Another Assignment</a>
          <a class="btn btn-primary" href="/reminder">Set Submission Reminder</a>
          <button class="btn btn-primary" type="button" data-download-checklist>Download Checklist</button>
        </div>
      </div>

      <% if (generatedReport) { %>
        <section class="feedback-summary-card generated-summary-card">
          <div class="question-summary-icon" aria-hidden="true">AI</div>

          <div class="feedback-summary-copy">
            <h2>Generated from uploaded documents</h2>
            <span class="status-pill">Gemini feedback</span>
            <p>This report is based only on the files submitted in this review. It is guidance for completion and readiness, not a grade prediction.</p>
          </div>

          <% if (uploadedFiles) { %>
            <div class="uploaded-file-summary">
              <div>
                <strong>Assignment Brief</strong>
                <span><%= uploadedFiles.assignmentBrief %></span>
              </div>
              <div>
                <strong>Marking Rubric</strong>
                <span><%= uploadedFiles.markingRubric %></span>
              </div>
              <div>
                <strong>Student Draft</strong>
                <span><%= uploadedFiles.studentDraft %></span>
              </div>
            </div>
          <% } %>
        </section>

        <article class="ai-report-card">
          <pre class="ai-report-text"><%= generatedReport %></pre>
        </article>

        <section class="follow-up-card" aria-labelledby="follow-up-title">
          <div class="follow-up-heading">
            <div>
              <h2 id="follow-up-title">Ask RubriCheck AI a follow-up question</h2>
              <p>Ask about this feedback report, the uploaded documents, or which improvement to focus on first.</p>
            </div>
          </div>

          <form class="follow-up-form" data-follow-up-form>
            <input type="hidden" name="reviewId" value="<%= generatedReviewId %>">
            <label for="follow-up-question" class="sr-only">Follow-up question</label>
            <textarea id="follow-up-question" name="question" rows="4" maxlength="1000" placeholder="What should I fix first?" required data-follow-up-question></textarea>
            <div class="follow-up-actions">
              <p class="follow-up-note">Answers are limited to the uploaded documents and this feedback report.</p>
              <button class="btn btn-primary" type="submit" data-follow-up-submit>Ask RubriCheck AI</button>
            </div>
          </form>

          <p class="follow-up-error hidden" data-follow-up-error role="alert"></p>
          <article class="follow-up-answer hidden" data-follow-up-answer aria-live="polite"></article>
        </section>
      <% } else { %>
        <section class="report-empty-state">
          <h2>No feedback report yet</h2>
          <p>Start from New Review, fill in the student information, upload the assignment brief, marking rubric, and student draft, then check the assignment to generate the connected Gemini feedback report.</p>
          <a class="btn btn-primary" href="/upload">Go to New Review</a>
        </section>
      <% } %>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
