<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | Feedback</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container nav-bar">
      <a class="brand" href="/" aria-label="RubriCheck AI home">
        <img class="brand-logo" src="/images/RubriCheck%20Logo.png" alt="RubriCheck AI logo">
        <span class="brand-name">Rubri<span>Check</span> <small>AI</small></span>
      </a>

      <nav class="main-nav" aria-label="Main navigation">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/upload">New Review</a>
      </nav>

      <div class="auth-area" aria-label="Account actions">
        <button class="login-button" type="button" data-login-open>Log In</button>

        <a class="user-chip hidden" href="/dashboard" aria-label="Open user dashboard" data-user-chip>
          <span class="user-icon">DS</span>
          <span>Demo Student</span>
        </a>
      </div>
    </div>
  </header>

  <div class="modal-overlay hidden" data-login-modal>
    <section class="login-modal" role="dialog" aria-modal="true" aria-labelledby="login-title">
      <button class="modal-close" type="button" aria-label="Close login" data-login-close>&times;</button>

      <img class="modal-logo" src="/images/RubriCheck%20Logo.png" alt="RubriCheck AI logo">
      <h2 id="login-title">Log in to RubriCheck AI</h2>
      <p>This is a frontend demo login. No real account or password is needed yet.</p>

      <form class="login-form">
        <label for="demo-email">Email</label>
        <input id="demo-email" type="email" value="student@myrp.edu.sg" readonly>

        <label for="demo-password">Password</label>
        <input id="demo-password" type="password" value="password" readonly>

        <button class="btn btn-primary" type="button" data-demo-login>Use Demo Login</button>
      </form>
    </section>
  </div>

  <% const generatedReport = typeof report === 'undefined' ? null : report; %>
  <% const uploadedFiles = typeof files === 'undefined' ? null : files; %>
  <% const generatedReviewId = typeof reviewId === 'undefined' ? null : reviewId; %>

  <main class="feedback-page">
    <section class="feedback-shell container">
      <div class="feedback-header">
        <div>
          <p class="feedback-kicker" data-feedback-kicker><%= generatedReport ? 'RubriCheck AI report' : 'Business Analytics Report - Q2 2025' %></p>
          <h1>AI Feedback Report</h1>
          <p>Review your assignment readiness and improvement areas before submission.</p>
        </div>

        <div class="feedback-actions">
          <a class="btn btn-secondary" href="/questions">Prepare Lecturer Questions</a>
          <a class="btn btn-secondary" href="/upload">Check Another Assignment</a>
          <a class="btn btn-primary" href="/reminder">Set Submission Reminder</a>
          <button class="btn btn-primary" type="button" data-download-checklist>Download Checklist</button>
        </div>
      </div>

      <% if (generatedReport) { %>
        <section class="feedback-summary-card generated-summary-card">
          <div class="question-summary-icon" aria-hidden="true">AI</div>

          <div class="feedback-summary-copy">
            <h2>Generated from uploaded documents</h2>
            <span class="status-pill">Gemini feedback</span>
            <p>This report is based only on the files submitted in this review. It is guidance for completion and readiness, not a grade prediction.</p>
          </div>

          <% if (uploadedFiles) { %>
            <div class="uploaded-file-summary">
              <div>
                <strong>Assignment Brief</strong>
                <span><%= uploadedFiles.assignmentBrief %></span>
              </div>
              <div>
                <strong>Marking Rubric</strong>
                <span><%= uploadedFiles.markingRubric %></span>
              </div>
              <div>
                <strong>Student Draft</strong>
                <span><%= uploadedFiles.studentDraft %></span>
              </div>
            </div>
          <% } %>
        </section>

        <article class="ai-report-card">
          <pre class="ai-report-text"><%= generatedReport %></pre>
        </article>

        <section class="follow-up-card" aria-labelledby="follow-up-title">
          <div class="follow-up-heading">
            <div>
              <h2 id="follow-up-title">Ask RubriCheck AI a follow-up question</h2>
              <p>Ask about this feedback report, the uploaded documents, or which improvement to focus on first.</p>
            </div>
          </div>

          <form class="follow-up-form" data-follow-up-form>
            <input type="hidden" name="reviewId" value="<%= generatedReviewId %>">
            <label for="follow-up-question" class="sr-only">Follow-up question</label>
            <textarea id="follow-up-question" name="question" rows="4" maxlength="1000" placeholder="What should I fix first?" required data-follow-up-question></textarea>
            <div class="follow-up-actions">
              <p class="follow-up-note">Answers are limited to the uploaded documents and this feedback report.</p>
              <button class="btn btn-primary" type="submit" data-follow-up-submit>Ask RubriCheck AI</button>
            </div>
          </form>

          <p class="follow-up-error hidden" data-follow-up-error role="alert"></p>
          <article class="follow-up-answer hidden" data-follow-up-answer aria-live="polite"></article>
        </section>
      <% } else { %>
        <section class="feedback-summary-card">
          <div class="score-ring feedback-score-ring">
            <span data-feedback-score>78</span>
            <small>/ 100</small>
          </div>

          <div class="feedback-summary-copy">
            <h2 data-feedback-heading>Overall Readiness: 78%</h2>
            <span class="status-pill" data-feedback-status>Almost Ready</span>
            <p data-feedback-summary>Your assignment demonstrates solid research and methodology. Key gaps exist in critical evaluation and limitations; addressing these could push your score above 90%.</p>
          </div>

          <div class="feedback-metrics" data-feedback-metrics>
            <div class="metric-card positive">
              <strong>4</strong>
              <span>Strengths</span>
            </div>
            <div class="metric-card warning">
              <strong>4</strong>
              <span>Improvements</span>
            </div>
            <div class="metric-card danger">
              <strong>2</strong>
              <span>Missing criteria</span>
            </div>
          </div>
        </section>

        <div class="report-tabs" role="tablist" aria-label="Feedback report sections">
          <button class="report-tab active" type="button" role="tab" aria-selected="true" data-report-tab="overview">Overview</button>
          <button class="report-tab" type="button" role="tab" aria-selected="false" data-report-tab="suggestions">Suggestions</button>
          <button class="report-tab" type="button" role="tab" aria-selected="false" data-report-tab="checklist">Checklist</button>
        </div>

        <section class="report-panel active" data-report-panel="overview">
          <div class="overview-grid">
            <article class="report-card accent-green">
              <h2>Strengths</h2>
              <ul class="report-list" data-strength-list>
                <li>Clear problem statement with well-defined research objectives in the introduction.</li>
                <li>Strong literature review using recent sources and relevant industry examples.</li>
                <li>Methodology section shows good understanding of quantitative research design.</li>
                <li>Data visualisations are labelled clearly and connected to the findings.</li>
              </ul>
            </article>

            <article class="report-card accent-orange">
              <h2>Areas for Improvement</h2>
              <ul class="report-list" data-improvement-list>
                <li>Explanation depth is uneven in the analysis section and needs clearer reasoning.</li>
                <li>Some claims need stronger evidence from the dataset or cited references.</li>
                <li>Conclusion should connect back to the research limitations and rubric criteria.</li>
                <li>APA 7th citation formatting is inconsistent across several references.</li>
              </ul>
            </article>
          </div>

          <article class="report-card missing-card accent-red">
            <h2>Missing Rubric Requirements</h2>
            <div class="missing-grid" data-missing-criteria>
              <div class="missing-item danger">
                <strong>Critical Evaluation of Alternatives</strong>
                <span>20% of total mark</span>
                <em>Missing</em>
              </div>
              <div class="missing-item warning">
                <strong>Stakeholder Impact Analysis</strong>
                <span>10% of total mark</span>
                <em>Partial</em>
              </div>
              <div class="missing-item warning">
                <strong>Limitations &amp; Future Work</strong>
                <span>15% of total mark</span>
                <em>Partial</em>
              </div>
              <div class="missing-item danger">
                <strong>Professional Formatting (APA 7th)</strong>
                <span>5% of total mark</span>
                <em>Missing</em>
              </div>
            </div>
          </article>
        </section>

        <section class="report-panel" data-report-panel="suggestions" data-suggestions-list>
          <article class="suggestion-card">
            <div>
              <h2>Critical Evaluation</h2>
              <span class="priority high">High Priority</span>
            </div>
            <p><strong>Issue found:</strong> The report explains your selected solution but does not compare it against alternatives.</p>
            <p><strong>Suggested improvement:</strong> Add a subsection comparing at least two alternative approaches using cost, feasibility, and impact.</p>
            <p><strong>Example action:</strong> Add a decision matrix showing why your recommended solution is stronger than the alternatives.</p>
          </article>
        </section>

        <section class="report-panel" data-report-panel="checklist">
          <article class="report-card checklist-report-card">
            <div class="checklist-heading">
              <div>
                <h2>Submission Checklist</h2>
                <p data-checklist-summary>6 of 8 items complete</p>
              </div>
              <strong><span data-checklist-percent>75%</span> <span>complete</span></strong>
            </div>

            <div class="checklist-progress">
              <span style="width: 75%;" data-checklist-progress></span>
            </div>

            <ul class="submission-checklist" data-feedback-checklist>
              <li class="done"><span>&#10003;</span>Assignment draft uploaded</li>
              <li class="done"><span>&#10003;</span>Rubric criteria checked</li>
              <li class="done"><span>&#10003;</span>Introduction clearly explains purpose</li>
              <li class="done"><span>&#10003;</span>Evidence added to support points</li>
              <li class="todo"><span></span>Missing rubric criteria addressed</li>
              <li class="done"><span>&#10003;</span>Formatting reviewed</li>
              <li class="done"><span>&#10003;</span>References checked</li>
              <li class="todo"><span></span>Final proofreading completed</li>
            </ul>

            <button class="btn btn-primary checklist-download-button" type="button" data-download-checklist>Download Checklist</button>
          </article>
        </section>
      <% } %>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
