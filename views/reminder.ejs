<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | Submission Reminder</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { activePage: '' }) %>

  <%
    const reminderStudent = typeof studentInfo === 'undefined' || !studentInfo ? {} : studentInfo;
    const reminderSummary = typeof summary === 'undefined' || !summary ? {} : summary;

    function reminderListText(value, fallback) {
      if (Array.isArray(value) && value.length > 0) {
        return value.join('\n');
      }

      return fallback;
    }

    function reminderDateTime(value) {
      if (!value) {
        return '';
      }

      if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
        return `${value}T23:59`;
      }

      return value;
    }

    const reminderDefaults = {
      studentName: reminderStudent.studentName || '',
      telegramChatId: reminderStudent.telegramChatId || '',
      moduleCode: reminderStudent.moduleCode || '',
      assignmentName: reminderStudent.assignmentName || '',
      deadline: reminderDateTime(reminderStudent.deadline),
      readinessScore: reminderSummary.readinessScore || reminderSummary.completionPercentage || '',
      top3Priorities: reminderListText(reminderSummary.topPriorities, ''),
      checklist: reminderListText(reminderSummary.checklist, '')
    };
  %>

  <main class="reminder-page">
    <section class="reminder-shell container">
      <article class="reminder-card">
        <div class="reminder-header">
          <div>
            <p class="dashboard-kicker">Submission Reminder</p>
            <h1>Rubric Checker AI - Submission Reminder Form</h1>
            <p>Save your assignment details to receive Telegram reminders before your submission deadline.</p>
          </div>
        </div>

        <form class="reminder-form" data-reminder-form>
          <div class="reminder-grid">
            <div class="form-field">
              <label for="student-name">Student Name</label>
              <input id="student-name" name="studentName" type="text" value="<%= reminderDefaults.studentName %>" placeholder="Student Name" required data-reminder-required>
            </div>

            <div class="form-field">
              <label for="telegram-chat-id">Telegram Chat ID</label>
              <input id="telegram-chat-id" name="telegramChatId" type="text" value="<%= reminderDefaults.telegramChatId %>" placeholder="Enter your Telegram Chat ID" required data-reminder-required>
            </div>

            <div class="form-field">
              <label for="module-code">Module Code</label>
              <input id="module-code" name="moduleCode" type="text" value="<%= reminderDefaults.moduleCode %>" placeholder="Module Code" required data-reminder-required>
            </div>

            <div class="form-field">
              <label for="assignment-name">Assignment Name</label>
              <input id="assignment-name" name="assignmentName" type="text" value="<%= reminderDefaults.assignmentName %>" placeholder="Assignment Name" required data-reminder-required>
            </div>

            <div class="form-field">
              <label for="deadline">Deadline</label>
              <input id="deadline" name="deadline" type="datetime-local" value="<%= reminderDefaults.deadline %>" required data-reminder-required>
            </div>

            <div class="form-field">
              <label for="readiness-score">Readiness Score</label>
              <input id="readiness-score" name="readinessScore" type="number" min="0" max="100" value="<%= reminderDefaults.readinessScore %>" placeholder="Readiness Score" required data-reminder-required>
            </div>
          </div>

          <div class="reminder-detail-grid">
            <section class="reminder-list-card">
              <label for="top-3-priorities">Top 3 Priorities</label>
              <textarea id="top-3-priorities" name="top3Priorities" rows="5" placeholder="Top 3 priorities from the AI report" required data-reminder-required><%= reminderDefaults.top3Priorities %></textarea>
            </section>

            <section class="reminder-list-card">
              <label for="checklist">Before-Submission Checklist</label>
              <textarea id="checklist" name="checklist" rows="5" placeholder="Checklist from the AI report" required data-reminder-required><%= reminderDefaults.checklist %></textarea>
            </section>
          </div>

          <button class="btn btn-primary reminder-save-button" type="submit">Save Reminder</button>
          <p class="reminder-error-message hidden" data-reminder-error>
            Please enter your Telegram Chat ID and deadline before saving.
          </p>
          <p class="reminder-success-message hidden" data-reminder-success>
            Reminder form is ready. Add the n8n webhook URL to connect automation.
          </p>
        </form>
      </article>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
