<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | New Review</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { activePage: 'upload' }) %>

  <main class="upload-page">
    <section class="upload-shell container">
      <div class="upload-heading">
        <span class="upload-page-icon" aria-hidden="true">UP</span>
        <h1>Upload your documents</h1>
        <p>Upload your assignment brief, marking rubric, and student draft. We support PDF, DOCX, and TXT files.</p>
      </div>

      <%- include('partials/uploadForm', { error: typeof error === 'undefined' ? null : error }) %>

      <div class="upload-trust-row" aria-label="Upload notes">
        <span>Files processed server-side</span>
        <span>API key protected</span>
        <span>Rubric-focused feedback</span>
      </div>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
