<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubriCheck AI | Analysing</title>
  <link rel="icon" type="image/png" href="/images/RubriCheck%20Logo.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { activePage: '' }) %>

  <main class="analysing-page">
    <section class="analysis-card" aria-labelledby="analysis-title">
      <div class="analysis-spinner" aria-hidden="true">
        <span>AI</span>
      </div>

      <h1 id="analysis-title">Analysing your assignment...</h1>
      <p>RubriCheck AI is comparing your assignment draft against the marking rubric.</p>

      <ol class="analysis-step-list" data-analysis-steps>
        <li class="analysis-step completed">
          <span class="step-status" aria-hidden="true">&#10003;</span>
          <span>Reading assignment draft</span>
        </li>
        <li class="analysis-step active">
          <span class="step-status" aria-hidden="true">DOC</span>
          <span>Understanding marking rubric</span>
          <span class="step-dots" aria-hidden="true">...</span>
        </li>
        <li class="analysis-step">
          <span class="step-status" aria-hidden="true">O</span>
          <span>Comparing rubric criteria</span>
        </li>
        <li class="analysis-step">
          <span class="step-status" aria-hidden="true">UP</span>
          <span>Identifying strengths and gaps</span>
        </li>
        <li class="analysis-step">
          <span class="step-status" aria-hidden="true">AI</span>
          <span>Generating improvement suggestions</span>
        </li>
        <li class="analysis-step">
          <span class="step-status" aria-hidden="true">CL</span>
          <span>Building submission checklist</span>
        </li>
      </ol>

      <div class="analysis-progress" aria-label="Analysis progress">
        <div class="analysis-progress-track">
          <span data-analysis-progress></span>
        </div>
        <small data-analysis-percent>17% complete</small>
      </div>

      <p class="analysis-note">This may take a few seconds.</p>
    </section>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
